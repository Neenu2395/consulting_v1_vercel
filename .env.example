# Copy to .env and fill in. In production, set these in Vercel
# (Project > Settings > Environment Variables) and redeploy.

# Cusdis comments App ID (https://cusdis.com > your site > App ID).
# Public value (ships in page HTML) — safe to expose. Blog comments stay
# hidden until this is set.
VITE_CUSDIS_APP_ID=

# Google Gemini API key (used by the evaluation flow, if enabled).
GEMINI_API_KEY=
