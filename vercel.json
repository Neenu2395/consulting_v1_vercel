{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/founders", "destination": "/founders.html" },
    { "source": "/services", "destination": "/services.html" },
    { "source": "/evaluate", "destination": "/evaluate.html" },
    { "source": "/success-stories", "destination": "/success-stories.html" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/blog/:slug", "destination": "/blog/:slug.html" },
    { "source": "/resources", "destination": "/resources.html" },
    { "source": "/resources/mba-application-checklist", "destination": "/resources/mba-application-checklist.html" },
    { "source": "/resources/mba-essay-brainstorming-worksheet", "destination": "/resources/mba-essay-brainstorming-worksheet.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
